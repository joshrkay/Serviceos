# Local-run env for deploy/docker-compose.prod.yml (+ docker-compose.dev-auth.yml).
# Copy to deploy/.env. These placeholders satisfy compose ${VAR:?} interpolation;
# under NODE_ENV=development (the dev-auth override) validateProductionConfig does
# NOT run, so they are inert. For a REAL production-shape run, replace them with
# actual secrets — see the repo-root .env.production.example for the full set.
POSTGRES_USER=serviceos
POSTGRES_PASSWORD=serviceos
POSTGRES_DB=serviceos
DB_MAX_CONNECTIONS=20
DB_DIRECT_MAX_CONNECTIONS=10
CLERK_SECRET_KEY=dev-placeholder
CLERK_PUBLISHABLE_KEY=dev-placeholder
CLERK_WEBHOOK_SECRET=dev-placeholder
CORS_ORIGIN=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_placeholder
AI_PROVIDER_API_KEY=
