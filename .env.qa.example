# QA Matrix env — LOCAL ONLY, not committed
#
# Setup (one time):
#
#   cp .env.qa.example .env.qa
#   # Uncomment and fill the three REQUIRED blocks below (Railway dashboard)
#   npm run qa:setup          # seed + mint + doctor
#   npm run qa:matrix:run     # or npm run qa:runbook
#
# Scripts auto-source .env.qa — you do NOT need `source .env.qa` before npm run.
# After qa:setup, tenant UUIDs are written to .env.qa.local (also auto-sourced).
#
# See docs/runbooks/qa-full-matrix-unblock.md
#
# IMPORTANT: this file is gitignored. Do NOT commit it.

# --- Railway dev URLs (optional — omit to use dev defaults) ---
# Railway dashboard → each service → Settings → Networking
# export E2E_BASE_URL="https://serviceosweb-development.up.railway.app"
# export E2E_API_URL="https://serviceosapi-development.up.railway.app"

# --- Postgres (REQUIRED) ---
# Railway → Postgres → Variables → DATABASE_PUBLIC_URL
# Use host shinkansen.proxy.rlwy.net (public proxy), NOT railway.internal.
# export E2E_DB_URL_READWRITE="postgres://USER:PASS@shinkansen.proxy.rlwy.net:PORT/railway"
# export E2E_DB_URL_READONLY="postgres://qa_readonly:PASS@shinkansen.proxy.rlwy.net:PORT/railway"

# --- API auth secret (REQUIRED) ---
# Railway → API service → Variables → CLERK_SECRET_KEY (copy the value)
# export E2E_CLERK_HMAC_SECRET="sk_test_..."

# --- Clerk testing tokens (optional — journey specs with real Clerk UI) ---
# See qa/reports/2026-05-11/clerk-testing-tokens-runbook.md
# export E2E_CLERK_PUBLISHABLE_KEY="pk_test_..."
# export E2E_CLERK_SECRET_KEY="sk_test_..."

# --- Matrix tenant IDs (optional — npm run qa:setup writes .env.qa.local) ---
# Only paste manually if you skip qa:setup and seed yourself:
# export E2E_TENANT_A_ID=...
# export E2E_TENANT_A_CUSTOMER_ID=...
# export E2E_TENANT_A_JOB_ID=...
# export E2E_TENANT_B_ID=...
# export E2E_TENANT_B_CUSTOMER_ID=...
# export E2E_TENANT_B_JOB_ID=...

# ============================================================================
# Journey-suite ephemeral DB
# ============================================================================
export E2E_USE_TEST_DB="false"
