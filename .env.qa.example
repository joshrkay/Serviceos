# QA Matrix env — LOCAL ONLY, not committed
#
# Copy to .env.qa, fill in the real values, then run the matrix:
#
#   cp .env.qa.example .env.qa
#   npm run e2e:qa-matrix
#
# When QA_MATRIX=1, playwright.config.ts auto-loads .env.qa from the repo root
# as a gap-fill: any var already set in your shell or CI wins (so `source
# .env.qa` is optional and never overridden), and empty values are ignored.
#
# IMPORTANT: this file is gitignored. Do NOT commit it.

# --- Railway dev URLs ---
# Railway dashboard → each service → Settings → Networking → copy the *.up.railway.app URL
export E2E_BASE_URL=""
export E2E_API_URL=""

# --- Postgres (public proxy host shinkansen.proxy.rlwy.net, not railway.internal) ---
# Railway → Postgres service → Variables → DATABASE_PUBLIC_URL (or copy DATABASE_URL
# value and swap the host to shinkansen.proxy.rlwy.net:<port>).
# Re-read AFTER rotating the password.
export E2E_DB_URL_READONLY=""

# --- API auth secret ---
# Railway → API service → Variables → CLERK_SECRET_KEY (copy the *value*, not the reference)
# Must match exactly what the deployed API uses — tokens are HMAC-signed locally.
export E2E_CLERK_HMAC_SECRET=""

# --- Clerk testing tokens (for journey specs that drive real Clerk UI) ---
# Both come from the Clerk dev instance with "Testing mode" enabled.
# Dashboard → your dev instance → Configure → API keys.
# See qa/reports/2026-05-11/clerk-testing-tokens-runbook.md.
export E2E_CLERK_PUBLISHABLE_KEY=""   # pk_test_...
export E2E_CLERK_SECRET_KEY=""        # sk_test_...

# --- Seeded tenant / customer / job IDs (from fixtures/seed.ts output; not sensitive) ---
# These are the LONG-LIVED qa-matrix IDs against the Railway dev DB. They're
# distinct from the per-run journey seeds written by e2e/fixtures/seed-journey-fixtures.ts.
export E2E_TENANT_A_ID=a948cc66-7279-44bd-9718-4ef7721f9422
export E2E_TENANT_A_CUSTOMER_ID=ad009e33-b141-4485-9030-50c5fe016820
export E2E_TENANT_A_JOB_ID=557ffc41-d5bc-48dc-a1a0-f7775cc6c700
export E2E_TENANT_B_ID=ce4d752d-651a-4b72-8a01-f7113fba9454
export E2E_TENANT_B_CUSTOMER_ID=e38746cf-64bb-4d0d-b22d-cfdb2e969d82
export E2E_TENANT_B_JOB_ID=ccaa94e8-cf47-40f1-a743-473d2ff11fb2

# ============================================================================
# Journey-suite ephemeral DB (owned by DB-fixtures agent)
# ============================================================================
# Activates the auto-managed test DB. When this is "true", Playwright globalSetup
# will run e2e/fixtures/setup-test-db.ts + seed-journey-fixtures.ts before the
# suite starts. teardown-test-db.ts runs after. See:
#   qa/reports/2026-05-11/ephemeral-test-db-runbook.md
export E2E_USE_TEST_DB="false"

# When E2E_USE_TEST_DB=true:
#   - If DATABASE_URL is set, the scripts will migrate + seed THAT DB (it MUST
#     contain 'test', 'e2e', 'ephemeral', or 'ci' in the database name; the
#     safety guard will refuse anything else).
#   - If DATABASE_URL is unset, the scripts spin up a pgvector/pgvector:pg16
#     testcontainer locally. Docker must be available.
# Leave commented out for the testcontainer path.
# export DATABASE_URL="postgres://user:pass@host:5432/serviceos_e2e_test"

# OPTIONAL escape hatch — set to '1' to bypass the safety heuristic (NOT
# recommended; the runbook explains the few cases this is safe).
# export E2E_DB_ALLOW_UNSAFE="0"
