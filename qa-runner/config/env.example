# QA Runner — Environment Variables
# Copy to .env and fill in before running: cp config/env.example .env

# ── Required for all tests ───────────────────────────────────────────────────

# Base URL of the deployed web app (no trailing slash)
BASE_URL=https://serviceosweb-development.up.railway.app

# Base URL of the deployed API (no trailing slash)
API_URL=https://serviceosapi-development.up.railway.app

# ── Required for authenticated tests ────────────────────────────────────────

# Clerk JWT for Tenant A (the primary test account). Get this by signing in
# to the app, then in DevTools → Application → Cookies → __session, or by
# calling window.Clerk.session.getToken() in the browser console.
AUTH_BEARER_TOKEN=

# Tenant A's UUID. Required for endpoints that need an explicit x-tenant-id
# header (e.g., /api/dispatch/board). Find this on /settings or by calling
# /api/me with the AUTH_BEARER_TOKEN above.
TENANT_ID=

# ── Required for cross-tenant isolation tests (ISO-009 through ISO-013) ─────

# Clerk JWT for a SECOND account (Tenant B). Must be a different email from
# AUTH_BEARER_TOKEN — this simulates an attacker with a valid session trying
# to access another tenant's data.
TENANT_B_TOKEN=

# IDs of Tenant A entities used in cross-tenant read/write attempts.
# Run the manual runbook §2–§6 first, then paste the IDs here from the
# browser URL bar or DevTools Network tab responses.
TENANT_A_CUSTOMER_ID=
TENANT_A_ESTIMATE_ID=
TENANT_A_INVOICE_ID=
TENANT_A_JOB_ID=

# ── Required for DB verification (optional but strongly recommended) ─────────

# Shell command that accepts a SQL query as its first argument and prints
# the result to stdout. Examples:
#   psql "$DATABASE_URL" -c
#   railway run -- psql "$DATABASE_URL" -c
#
# The runner invokes it as: $DB_CHECK_COMMAND "<sql>"
DB_CHECK_COMMAND=
