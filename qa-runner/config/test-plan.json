          "api_check": {
            "method": "GET",
            "endpoint": "/api/settings",
            "expect_statuses": [401, 403]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": { "query": "SELECT 1 AS ok;", "required": false }
        },
        {
          "id": "ISO-007",
          "description": "Unauthenticated GET /api/contracts returns 401",
          "module": "tenant-isolation",
          "api_check": {
            "method": "GET",
            "endpoint": "/api/contracts",
            "expect_statuses": [401, 403]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": { "query": "SELECT 1 AS ok;", "required": false }
        },
        {
          "id": "ISO-008",
          "description": "Unauthenticated GET /api/proposals returns 401",
          "module": "tenant-isolation",
          "api_check": {
            "method": "GET",
            "endpoint": "/api/proposals",
            "expect_statuses": [401, 403]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": { "query": "SELECT 1 AS ok;", "required": false }
        },
        {
          "id": "ISO-009",
          "description": "Cross-tenant customer read (Tenant B token, Tenant A customer ID) — requires TENANT_B_TOKEN and TENANT_A_CUSTOMER_ID",
          "module": "tenant-isolation",
          "requires_env": ["TENANT_B_TOKEN", "TENANT_A_CUSTOMER_ID"],
          "api_check": {
            "method": "GET",
            "endpoint": "/api/customers/{{TENANT_A_CUSTOMER_ID}}",
            "headers": { "Authorization": "Bearer {{TENANT_B_TOKEN}}" },
            "expect_statuses": [403, 404]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": { "query": "SELECT 1 AS ok;", "required": false }
        },
        {
          "id": "ISO-010",
          "description": "Cross-tenant estimate read — requires TENANT_B_TOKEN and TENANT_A_ESTIMATE_ID",
          "module": "tenant-isolation",
          "requires_env": ["TENANT_B_TOKEN", "TENANT_A_ESTIMATE_ID"],
          "api_check": {
            "method": "GET",
