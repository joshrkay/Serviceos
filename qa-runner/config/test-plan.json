          "id": "ISO-011",
          "description": "Cross-tenant invoice read — requires TENANT_B_TOKEN and TENANT_A_INVOICE_ID",
          "module": "tenant-isolation",
          "requires_env": ["TENANT_B_TOKEN", "TENANT_A_INVOICE_ID"],
          "api_check": {
            "method": "GET",
            "endpoint": "/api/invoices/{{TENANT_A_INVOICE_ID}}",
            "headers": { "Authorization": "Bearer {{TENANT_B_TOKEN}}" },
            "expect_statuses": [403, 404]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": { "query": "SELECT 1 AS ok;", "required": false }
        },
        {
          "id": "ISO-012",
          "description": "Cross-tenant job read — requires TENANT_B_TOKEN and TENANT_A_JOB_ID",
          "module": "tenant-isolation",
          "requires_env": ["TENANT_B_TOKEN", "TENANT_A_JOB_ID"],
          "api_check": {
            "method": "GET",
            "endpoint": "/api/jobs/{{TENANT_A_JOB_ID}}",
            "headers": { "Authorization": "Bearer {{TENANT_B_TOKEN}}" },
            "expect_statuses": [403, 404]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": { "query": "SELECT 1 AS ok;", "required": false }
        },
        {
          "id": "ISO-013",
          "description": "Cross-tenant note write — requires TENANT_B_TOKEN and TENANT_A_CUSTOMER_ID",
          "module": "tenant-isolation",
          "requires_env": ["TENANT_B_TOKEN", "TENANT_A_CUSTOMER_ID"],
          "api_check": {
            "method": "POST",
            "endpoint": "/api/notes",
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer {{TENANT_B_TOKEN}}"
            },
            "body": {
              "entityType": "customer",
              "entityId": "{{TENANT_A_CUSTOMER_ID}}",
              "content": "Cross-tenant injection attempt"
            },
            "expect_statuses": [403, 404]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": {
            "query": "SELECT COUNT(*) AS c FROM notes WHERE content = 'Cross-tenant injection attempt';",
            "required": false
          }
        },
        {
