          "db_check": {
            "query": "SELECT COUNT(*) AS c FROM tenant_settings;",
            "required": false
          }
        }
      ]
    },

    {
      "name": "customers",
      "description": "Runbook §2 — customer CRUD and service locations",
      "depends_on": ["auth"],
      "tests": [
        {
          "id": "CUST-001",
          "description": "Create customer returns 201 with id",
          "module": "customers",
          "requires_env": ["AUTH_BEARER_TOKEN"],
          "api_check": {
            "method": "POST",
            "endpoint": "/api/customers",
            "headers": { "Content-Type": "application/json" },
            "body": {
              "firstName": "QA",
              "lastName": "Customer{{timestamp}}",
              "primaryPhone": "+15555{{rand4}}",
              "email": "qa+{{timestamp}}@example.com"
            },
            "expect_statuses": [200, 201]
          },
          "ui_check": { "path": "/customers", "expect_text": "Customers" },
          "db_check": {
            "query": "SELECT COUNT(*) AS c FROM customers WHERE first_name = 'QA';",
            "required": false
          }
        },
        {
          "id": "CUST-002",
          "description": "List customers returns array",
          "module": "customers",
          "requires_env": ["AUTH_BEARER_TOKEN"],
          "api_check": {
            "method": "GET",
            "endpoint": "/api/customers",
