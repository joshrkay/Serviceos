    {
      "name": "auth",
      "description": "Runbook §1 — authenticated session and tenant bootstrap verification",
      "depends_on": ["infrastructure"],
      "tests": [
        {
          "id": "AUTH-001",
          "description": "Authenticated /api/me returns tenantId",
          "module": "auth",
          "requires_env": ["AUTH_BEARER_TOKEN"],
          "api_check": {
            "method": "GET",
            "endpoint": "/api/me",
            "expect_statuses": [200]
          },
          "ui_check": { "path": "/", "expect_text": "Fieldly" },
          "db_check": {
            "query": "SELECT COUNT(*) AS c FROM tenants WHERE id = current_setting('app.current_tenant_id')::uuid;",
            "required": false
          }
        },
        {
          "id": "AUTH-002",
          "description": "Tenant settings row exists after bootstrap",
          "module": "auth",
          "requires_env": ["AUTH_BEARER_TOKEN"],
          "api_check": {
