    {
      "name": "tenant-isolation",
      "description": "Runbook §17 — cross-tenant API read and write isolation using a second token",
      "depends_on": ["customers", "estimates", "invoices"],
      "tests": [
        {
          "id": "ISO-001",
          "description": "Unauthenticated GET /api/customers returns 401",
          "module": "tenant-isolation",
          "api_check": {
            "method": "GET",
            "endpoint": "/api/customers",
            "expect_statuses": [401, 403]
          },
          "ui_check": { "path": "/login", "expect_text": "Fieldly" },
          "db_check": { "query": "SELECT 1 AS ok;", "required": false }
        },
        {
          "id": "ISO-002",
          "description": "Unauthenticated GET /api/estimates returns 401",
          "module": "tenant-isolation",
