# ─────────────────────────────────────────────────────────────────────────
# Rivet (ServiceOS) — PRODUCTION environment template
#
# Launch-critical subset of variables, organized by failure tier. For the
# exhaustive list (dev defaults, QA/E2E, advisory voice vars) see .env.example
# and docs/prod-env-checklist.md. Set these as Railway service variables on the
# API service (and the VITE_* block as build-time vars on the web service).
#
# DO NOT commit real secret values. This file is a template only.
# Procedure: docs/launch/GO-LIVE-RUNBOOK.md
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ═══ TIER 0 — BOOT-FAIL ═══════════════════════════════════════════════════
# Missing any of these → the API process refuses to start in production
# (validateProductionConfig, packages/api/src/shared/config.ts; the Stripe key
# is enforced by createPaymentLinkProvider at boot, app.ts:966).

# Railway injects DATABASE_URL automatically when a Postgres plugin is linked.
# Scaling to many replicas: point DATABASE_URL at PgBouncer (transaction mode)
# so N app pools multiplex onto a bounded Postgres max_connections. The request
# hot path is transaction-pooling-safe (SET LOCAL tenant context). See
# docs/runbooks/scaling.md.
DATABASE_URL=

# DIRECT (session-mode) Postgres DSN that BYPASSES PgBouncer. Required ONLY when
# DATABASE_URL points at PgBouncer: session-scoped state — leader-election
# advisory locks, the proposal idempotency lock, and LISTEN/NOTIFY — must hold a
# stable backend and breaks under transaction pooling. Leave UNSET when not
# using PgBouncer; the app then reuses DATABASE_URL for those (identical to
# single-instance behavior). createDirectPool(), packages/api/src/db/pool.ts.
# NOTE: pre-deploy migrations (railway.toml preDeployCommand -> migrate.js) run
# through this DIRECT DSN when set — DDL + session SET lock_timeout/statement_timeout
# must NOT go through transaction-mode PgBouncer. Falls back to DATABASE_URL when unset.
DATABASE_DIRECT_URL=

# Per-replica app pool size. Rule of thumb: max ≈ vCPU * 4 (bounded by expected
# concurrent OPEN transactions per replica — keep request transactions short so
# PgBouncer multiplexes). Across N replicas this is the PgBouncer client side;
# PgBouncer's server pool (DEFAULT_POOL_SIZE) is what bounds real Postgres
# connections. Watch the db_pool_connections{state="waiting"} metric.
DB_MAX_CONNECTIONS=20
# Small pool for the direct (session) DSN — only the lock holders + LISTEN use it.
DB_DIRECT_MAX_CONNECTIONS=10

# Redis — shared state across replicas. UNSET = single-instance (every shared
# store falls back to its in-memory implementation, byte-identical to today).
# Set this before running > 1 replica so WS connection caps are cluster-wide and
# voice events fan out across replicas. See docs/runbooks/scaling.md.
REDIS_URL=
# Mirror live voice events across replicas over Redis pub/sub so the supervisor
# wall and client WS gateway can observe calls owned by another replica. Requires
# REDIS_URL too; dark-launch switch — leave 'false' until > 1 replica.
VOICE_FANOUT_ENABLED=false

# Queue throughput (P3): messages claimed + processed concurrently per 250ms poll
# tick (FOR UPDATE SKIP LOCKED keeps it multi-replica-safe). Raise to lift the
# per-process rate; total throughput also scales with replica count.
QUEUE_POLL_BATCH_SIZE=10
# Per-tenant /api request cap per minute (P3), enforced cluster-wide when
# REDIS_URL is set (else per-process). Coarse per-IP DoS limits are separate and
# always on. Sized so one tenant's dashboards/integrations can't starve a replica.
API_TENANT_RATE_LIMIT_MAX=1000
# T4-F02 — /api per-IP request cap per 15min window; a DoS guard, NOT the
# fairness control (API_TENANT_RATE_LIMIT_MAX above is). Default 2000 avoids
# starving a shared-NAT office's normal multi-user traffic; tighten if abuse
# patterns emerge.
API_IP_RATE_LIMIT_MAX=2000
# T4-F02 — /webhooks/{stripe,clerk,vapi,twilio,wisetack,sendgrid} request cap
# per minute, mounted before the general /webhooks limiter (30/min) so
# legitimate provider callback bursts aren't 429'd ahead of signature
# verification. Unknown/junk /webhooks/* paths stay on the 30/min limit.
WEBHOOK_PROVIDER_RATE_LIMIT_MAX=600

# Clerk → API keys (Production instance → API Keys). Must be pk_live_ / sk_live_
# (validateEnvSchema refuses test keys unless ALLOW_CLERK_TEST_KEYS=true).
# Also create JWT template "serviceos" on this instance — without it the web
# client cannot mint API tokens. See docs/runbooks/clerk-setup.md.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# ALLOW_CLERK_TEST_KEYS=true   # staging-only escape hatch for pk_test_/sk_test_

# Clerk webhook signing secret (Clerk dashboard → Webhooks → your endpoint →
# Signing Secret). Pairs with the POST /webhooks/clerk endpoint. Missing → the
# Clerk user.created webhook 500s and tenants are never bootstrapped.
# Webhook must also PATCH public_metadata { tenant_id, role } (handler does this).
CLERK_WEBHOOK_SECRET=

# LLM gateway (OpenAI-compatible). Without AI_PROVIDER_API_KEY the ENTIRE AI
# pipeline is an inert mock (intent classification returns "unknown").
# Host + model IDs must match — see docs/runbooks/live-ai-restore.md
# Static check: cd packages/api && npm run check:ai-provider-config
#
# Profile B (recommended go-live) — OpenRouter managed open models:
# docs/runbooks/openrouter-ai-provider.md
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
AI_LIGHTWEIGHT_MODEL=meta-llama/llama-3.1-8b-instruct
AI_STANDARD_MODEL=meta-llama/llama-3.3-70b-instruct
AI_COMPLEX_MODEL=qwen/qwen2.5-vl-72b-instruct
#
# Profile A (immediate) — OpenAI direct when the key is already sk-… OpenAI.
# Unset the Llama/Qwen tier vars above when using this block:
# AI_PROVIDER_API_KEY=sk-...
# AI_PROVIDER_BASE_URL=https://api.openai.com/v1
# AI_DEFAULT_MODEL=gpt-4o-mini
# AI_LIGHTWEIGHT_MODEL=gpt-4o-mini
# AI_STANDARD_MODEL=gpt-4o-mini
# AI_COMPLEX_MODEL=gpt-4o
# Voice classifier's independent end-to-end budget. Empty string falls back to
# the 4s code default — keep this set (prod tuned: 12000). Never leave blank.
# AI_CLASSIFY_INTENT_DEADLINE_MS=12000
#
# Dual-provider failover (FM-03): keep Profile A as PRIMARY; add OpenRouter as
# FALLBACK only. Both key + URL required. Not the same as Profile B primary swap.
# AI_FALLBACK_PROVIDER_API_KEY=sk-or-...
# AI_FALLBACK_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
# AI_FALLBACK_LIGHTWEIGHT_MODEL=meta-llama/llama-3.1-8b-instruct
# AI_FALLBACK_STANDARD_MODEL=meta-llama/llama-3.3-70b-instruct
# AI_FALLBACK_COMPLEX_MODEL=qwen/qwen2.5-vl-72b-instruct

# Exact web origin (no wildcard). Must match the deployed web URL.
CORS_ORIGIN=https://app.yourdomain.com

# Stripe secret key (sk_live_...). Gates billingService + Connect + payment
# links; createPaymentLinkProvider throws at boot in prod if unset.
STRIPE_SECRET_KEY=

# Postgres Row-Level Security enforcement (SEC-01). REQUIRED in prod/staging —
# validateFeatureRequiredConfig (packages/api/src/shared/config.ts) refuses to
# boot without it set to the literal 'true'. When on, every tenant-scoped query
# drops to the least-privilege, RLS-subject rls_app_runtime role, so the
# tenant-isolation policies actually enforce (a forgotten tenant_id filter can no
# longer cross tenants). REQUIRES the rls_app_runtime role from migration 217 to
# be provisioned + granted to the app's DB user; the boot probe
# (verifyRlsRuntimeRole) fails fast if it is not. On managed Postgres where the
# app user lacks CREATEROLE, provision the role via the admin SQL in the runbook
# BEFORE the first prod/staging deploy. Procedure:
# docs/runbooks/rls-runtime-role-rollout.md.
RLS_RUNTIME_ROLE=true

# ═══ TIER 1 — SIGNUP → 14-DAY TRIAL → PAID ════════════════════════════════
# The commercial loop. Boots without these, but the loop silently 503s.

# Recurring price for the trial subscription (Stripe → Products → your plan →
# Price ID, price_...). Required by createTrialCheckoutSession (subscription.ts).
STRIPE_PRICE_ID=

# Stripe webhook signing secret(s) (Stripe dashboard → Developers → Webhooks →
# your endpoint → Signing secret, whsec_...). Pairs with POST /webhooks/stripe.
# Missing → boot-fails in prod/staging (SEC-43, validateProductionConfig); with
# it unset the trial→paid conversion could never land anyway (trialing state is
# written ONLY by customer.subscription.created).
# Full Stripe Connect coverage needs TWO endpoints (platform + connected
# accounts), each with its own secret — set BOTH here as a comma-separated list
# (whsec_platform,whsec_connected). A single value works for a single endpoint.
# See docs/runbooks/stripe-go-live.md.
STRIPE_WEBHOOK_SECRET=

# Base URL the API embeds in Stripe success/cancel redirects + upgrade emails.
# MUST be the real web URL (defaults to localhost:5173 — wrong in prod).
WEB_URL=https://app.yourdomain.com

# Optional: Stripe Billing Portal configuration id for the manage-subscription
# portal (Stripe → Billing → Customer portal). Stripe default used if unset.
# STRIPE_BILLING_PORTAL_CONFIGURATION=

# ═══ TIER 2 — FEATURE CREDENTIALS (required unless the feature is disabled) ═
# Telephony (inbound AI voice + SMS). Omit only with TELEPHONY_ENABLED=false.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_DEFAULT_TENANT_ID=
# Voice Media Streams (bidirectional live audio). THREE states (WS7):
#   false      → kill switch: every call uses Gather, full stop.
#   true       → forced on; boot REQUIRES TTS_PROVIDER=elevenlabs +
#                ELEVENLABS_API_KEY (enforced in shared/config.ts) because the
#                media-streams path needs raw PCM — the default OpenAI TTS
#                returns mp3 that plays as inaudible static (VOX-30).
#   unset/auto → on ONLY when the full stack is present: TTS_PROVIDER=elevenlabs
#                AND ELEVENLABS_API_KEY AND DEEPGRAM_API_KEY (all three). A
#                partial stack stays on Gather; auto never boot-crashes.
# NOTE: with all three keys set, leaving this unset now enables realtime on
# deploy. Pin 'false' to force Gather-only despite a complete key set.
# DEEPGRAM_API_KEY (STT) is required for any working stream. Railway does NOT
# read this file — set these in the API service's Variables.
TWILIO_MEDIA_STREAMS_ENABLED=false
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
# Email delivery (estimates/invoices). Omit only with EMAIL_ENABLED=false.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Object storage (recordings/uploads). Omit only with STORAGE_ENABLED=false.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ═══ TIER 3 — RUNTIME SECURITY / OPS (boot OK, but insecure/broken if unset) ═
# /metrics refuses (503) in prod without this — prevents tenant-id enumeration.
METRICS_TOKEN=
# Error tracking (no-op without it).
SENTRY_DSN=
# T4-F06 — REQUIRED in prod/staging (validateFeatureRequiredConfig,
# packages/api/src/shared/config.ts): a 64-char hex string (32 bytes).
# Encrypts tenant integration credentials (integrations/credentials.ts),
# calendar tokens (calendar-integration.ts), accounting tokens
# (accounting/token-crypto.ts), and Twilio provisioning secrets
# (workers/provision-twilio.ts); also the fallback key for transcript-at-rest
# encryption when TRANSCRIPT_ENCRYPTION_KEY is unset. Missing or malformed →
# the app now refuses to boot (previously crashed on first decrypt/encrypt at
# runtime). Generate with: openssl rand -hex 32
TENANT_ENCRYPTION_KEY=
# Raw voice-transcript encryption at rest (64-hex / 32-byte, format-checked at
# boot when set — see validateFeatureRequiredConfig). Optional: falls back to
# TENANT_ENCRYPTION_KEY above; set this only to use a DIFFERENT key for
# transcripts than for tenant credentials.
# TRANSCRIPT_ENCRYPTION_KEY=
# D-015 amendment — platform-wide kill switch for the autonomous booking lane
# (UB-D). Optional; unset/'false' preserves per-tenant opt-in gating
# (tenant_settings.autonomous_booking_enabled). Set 'true' for incident
# response to disable the lane for every tenant at once without a per-tenant
# settings sweep.
# AUTONOMOUS_BOOKING_DISABLED=false
# D-018 → DEPRECATED by D-019 (QUALITY-2026-07-12 WS2). There is no longer any
# autonomous CLOSE execution — the on-call close only STAGES proposals for owner
# one-tap approval (nothing is system-approved or executed). Still accepted as a
# platform-wide off switch for even PREPARING that owner-approval chain, checked
# independently of AUTONOMOUS_BOOKING_DISABLED. Optional; unset/'false' is the
# default.
# AUTONOMOUS_CLOSE_DISABLED=false
# WS15 — platform SLO monitor (workers/slo-monitor.ts; runbook
# docs/runbooks/slo-alerts.md). Evaluates every 5 min in worker/all roles and
# pages on breach: always a Sentry error event (needs SENTRY_DSN + the
# Sentry→Slack rules in docs/runbooks/alerting.md), plus an operator SMS when
# ALERT_SMS_TO is set. All knobs optional — the defaults shown are what apply
# when unset.
# Operator phone (E.164) for SLO breach SMS pages. Unset → Sentry-only.
# ALERT_SMS_TO=
# Min acceptable call completion rate over the trailing 60 min (0..1).
# SLO_CALL_COMPLETION_MIN=0.85
# Ended-call sample floor — below this many calls the completion rule never
# breaches (no 1-call false pages).
# SLO_CALL_COMPLETION_MIN_SAMPLE=5
# Pending queue jobs older than this many minutes are a breach (stuck queue).
# SLO_QUEUE_STALE_MIN=15
# Sweep-heartbeat age (minutes) above which the worker loop is presumed wedged.
# SLO_SWEEP_LAG_MIN=15
# WS26 — voice turn-latency P95 breach threshold (ms): media-streams STT-final →
# first TTS chunk. Only evaluated in-process under PROCESS_ROLE=all; split
# topologies alert via Prometheus (see docs/runbooks/slo-alerts.md).
# SLO_TURN_LATENCY_P95_MS=3500
# Min recorded turns before the turn-latency rule can breach (no early-boot pages).
# SLO_TURN_LATENCY_MIN_SAMPLE=30
# Per-rule re-page cooldown (minutes) for persistent breaches.
# SLO_ALERT_COOLDOWN_MIN=60

# QUALITY-2026-07-12 WS5 — Microsoft Presidio PII redaction for training assets
# (ai/privacy/presidio-adapter.ts). Two standard Presidio REST services: the
# Analyzer detects PII spans, the Anonymizer replaces them. Set BOTH to enable
# the Presidio-first redaction pass ahead of the deterministic scrub. When set,
# an unreachable/erroring backend FAILS CLOSED — the training asset is
# quarantined (reason: presidio_unavailable), never persisted with raw or
# regex-only text as active. Unset ⇒ local deterministic scrub only.
# PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
# PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000

# ═══ WEB SERVICE — BUILD-TIME (set on the @serviceos/web Railway service) ═══
VITE_API_URL=https://api.yourdomain.com
# Same Production publishable key as CLERK_PUBLISHABLE_KEY (pk_live_…).
# Also injected at container start into /env.js (packages/web/start.sh).
# Do NOT set VITE_AUTH_MODE=dev on this service.
VITE_CLERK_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
# Must be true in prod — drives the onboarding shell that hosts the billing step.
VITE_ONBOARDING_V2_ENABLED=true
