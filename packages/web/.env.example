# ServiceOS web — local dev environment template.
# Copy to .env.local and fill in real values. Never commit .env.local.

# ─── Clerk (REQUIRED — main.tsx throws at module load without this) ──────
# Get a test publishable key from https://dashboard.clerk.com/ (Development).
# Must match the API's CLERK_PUBLISHABLE_KEY for the same instance.
# Also create JWT template "serviceos" (tenant_id + role from public_metadata)
# or every authenticated API call will fail. See docs/runbooks/clerk-setup.md
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_CLERK_KEY

# Hermetic local/CI only — swaps Clerk for packages/web/src/dev/clerk-dev-shim.tsx.
# Pair with API DEV_AUTH_BYPASS=true. Never set on a real deploy.
# VITE_AUTH_MODE=dev

# ─── API base (optional — defaults to http://localhost:3000 via Vite proxy)
# VITE_API_URL=http://localhost:3000

# ─── Stripe (REQUIRED for public invoice payment page) ───────────────────────
# Get a publishable key from https://dashboard.stripe.com/apikeys
# Keys prefixed `pk_test_` are safe for dev; use live key in production.
# Required for customer self-service invoice payment (/pay/:token).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY

# ─── Onboarding v2 (§10 self-serve shell) ─────────────────────────────────
# Set false only for legacy wizard rollback.
VITE_ONBOARDING_V2_ENABLED=true

# ─── E2E only ─────────────────────────────────────────────────────────────
# When running Playwright journey specs locally, also export:
#   E2E_CLERK_PUBLISHABLE_KEY=$VITE_CLERK_PUBLISHABLE_KEY
#   E2E_CLERK_SECRET_KEY=sk_test_...   # never commit; from Clerk dashboard
# See qa/reports/2026-05-11/clerk-testing-tokens-runbook.md for the runbook.
