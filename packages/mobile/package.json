{
  "name": "@serviceos/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "//": "Isolated Expo project — intentionally NOT a root npm workspace. The root Dockerfile runs `npm ci` over packages/api|web|shared only; adding mobile to the root workspaces would either break that `npm ci` (missing workspace in the image) or pull the Expo/RN tree into the api image. Metro resolves @ai-service-os/shared from ../shared/src (see metro.config.js).",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "test": "vitest run",
    "test:rn": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.0",
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.0",
    "nativewind": "~4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
