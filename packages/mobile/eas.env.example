# EAS / Expo runtime env for packages/mobile builds.
# Copy values into EAS project env (do NOT commit secrets).
#
# Preferred:
#   npx eas-cli env:create --environment production --name EXPO_PUBLIC_API_URL --value https://...
#   npx eas-cli env:create --environment production --name EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY --value pk_live_...
#
# These are inlined at build time (see src/lib/env.ts). Leaving them unset
# falls back to localhost and breaks store / TestFlight builds.

EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Optional — only if you prefer env over app.json extra.eas.projectId
# (filled by `npx eas-cli init`; keep app.json projectId as "" until then)
# EAS_PROJECT_ID=

# Optional — Stripe Terminal Tap to Pay Test / simulated readers on preview builds
# EXPO_PUBLIC_TERMINAL_SIMULATED=1
