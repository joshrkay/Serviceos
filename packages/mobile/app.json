{
  "expo": {
    "name": "ServiceOS",
    "slug": "serviceos-mobile",
    "scheme": "serviceos",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.serviceos.app"
    },
    "android": {
      "package": "com.serviceos.app"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
