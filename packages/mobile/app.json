{
  "expo": {
    "name": "ServiceOS",
    "slug": "serviceos-mobile",
    "scheme": "serviceos",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#030213"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.serviceos.app"
    },
    "android": {
      "package": "com.serviceos.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow ServiceOS to use the microphone to capture voice actions."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
