# ServiceOS API — local dev environment template.
# Copy to .env and fill in real values. Never commit .env.

# ─── Minimum to boot (uses InMemory repos + MockLLM) ─────────────────────
NODE_ENV=dev
PORT=3000
LOG_LEVEL=debug

# ─── Postgres (optional in dev; required in staging/prod) ────────────────
# Without DATABASE_URL the API falls back to InMemory repositories and
# prints a loud startup warning. Fine for local voice-chain testing.
# DATABASE_URL=postgres://localhost:5432/serviceos

# ─── Clerk (required for the web UI — backend JWT verification) ──────────
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...
# CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json

# ─── AI provider (required for voice intent classifier + task handlers) ──
# Without this the voice-action-router classifies every transcript as
# "unknown" and drops it. Use the scripts/test-voice.ts harness with
# MOCK_RESPONSES to exercise the chain without a real key.
# AI_PROVIDER_API_KEY=sk-...
# AI_PROVIDER_BASE_URL=https://api.openai.com/v1
# AI_DEFAULT_MODEL=gpt-4o-mini

# ─── CORS (required in prod — must be an explicit origin, no wildcard) ───
# CORS_ORIGIN=http://localhost:5173

# ─── Stripe (optional for Phase 1 voice flows; needed for payment flow) ──
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Twilio (required when TELEPHONY_ENABLED=true OR EMAIL_ENABLED=true) ─
# TwilioDeliveryProvider couples SMS + SendGrid into one delivery service
# (see validateFeatureRequiredConfig in shared/config.ts:154), so even an
# email-only deployment needs the Twilio creds — without them
# /invoices/:id/send and /estimates/:id/send return 503. Set BOTH
# TELEPHONY_ENABLED=false and EMAIL_ENABLED=false to skip these checks for
# local dev that doesn't exercise the delivery path.
# TELEPHONY_ENABLED=true
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+15555550100
# Required only when telephony is enabled, until the multi-tenant
# phone-number lookup (B1) is fully on; inbound calls fall back to this
# tenant id when the lookup misses.
# TWILIO_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
# PUBLIC_API_URL=https://api.example.com   # Twilio signature verification base

# ─── SendGrid (required when EMAIL_ENABLED=true) ─────────────────────────
# EMAIL_ENABLED=true
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=hello@example.com

# ─── R2 / S3 (required when STORAGE_ENABLED=true) ────────────────────────
# STORAGE_ENABLED=true
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=serviceos-uploads
# R2_PUBLIC_URL=

# ─── Voice providers (optional; defaults to OpenAI Whisper STT / tts-1) ──
# DEEPGRAM_API_KEY=...      # Streaming STT for technician voice input
# ELEVENLABS_API_KEY=...    # Streaming TTS (D4-2; deferred to week 2)
# STT_PROVIDER=deepgram     # 'whisper' (default) or 'deepgram'
# TTS_PROVIDER=openai       # 'openai' (default) or 'elevenlabs'

# ─── Sentry (optional; initSentry() is a no-op when DSN unset) ───────────
# SENTRY_DSN=
