# ServiceOS API — local dev environment template.
# Copy to .env and fill in real values. Never commit .env.

# ─── Minimum to boot (uses InMemory repos + MockLLM) ─────────────────────
NODE_ENV=dev
PORT=3000
LOG_LEVEL=debug

# ─── Postgres (optional in dev; required in staging/prod) ────────────────
# Without DATABASE_URL the API falls back to InMemory repositories and
# prints a loud startup warning. Fine for local voice-chain testing.
# DATABASE_URL=postgres://localhost:5432/serviceos

# ─── Clerk (required for real auth — backend JWT verification) ──────────
# Use the Development instance (pk_test_ / sk_test_). Same instance as the
# web VITE_CLERK_PUBLISHABLE_KEY. Create JWT template "serviceos" with
# tenant_id + role claims — docs/runbooks/clerk-setup.md
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...
# Hermetic local (unsigned tokens) — pair with web VITE_AUTH_MODE=dev:
# DEV_AUTH_BYPASS=true
# CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json

# ─── AI provider (required for voice intent classifier + task handlers) ──
# Without this the voice-action-router classifies every transcript as
# "unknown" and drops it. Use the scripts/test-voice.ts harness with
# MOCK_RESPONSES to exercise the chain without a real key.
#
# Host and model IDs MUST match. Claude/Llama on api.openai.com fails every
# completion while /api/health/ai stays green. Profiles + Railway steps:
# docs/runbooks/live-ai-restore.md
# Static check: npm run check:ai-provider-config
#
# Profile B — OpenRouter (Option A, recommended go-live). Runbook:
# docs/runbooks/openrouter-ai-provider.md
# AI_PROVIDER_API_KEY=sk-or-...
# AI_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
# AI_LIGHTWEIGHT_MODEL=meta-llama/llama-3.1-8b-instruct
# AI_STANDARD_MODEL=meta-llama/llama-3.3-70b-instruct
# AI_COMPLEX_MODEL=qwen/qwen2.5-vl-72b-instruct
#
# Profile A — OpenAI direct (immediate fix when key is already OpenAI):
# AI_PROVIDER_API_KEY=sk-...
# AI_PROVIDER_BASE_URL=https://api.openai.com/v1
# AI_DEFAULT_MODEL=gpt-4o-mini
# AI_LIGHTWEIGHT_MODEL=gpt-4o-mini
# AI_STANDARD_MODEL=gpt-4o-mini
# AI_COMPLEX_MODEL=gpt-4o
# (Set all three tier vars so Llama/Qwen code defaults never win.)
# Voice intent classification carries the full taxonomy prompt; its 4s budget
# is independent of other lightweight tasks. Raise only with measured evidence.
# Production voice top-50: keep 12000. Never leave this set to "" (falls back to 4000).
# AI_CLASSIFY_INTENT_DEADLINE_MS=12000
#
# Dual-provider failover (Profile A primary + OpenRouter fallback) — both required:
# AI_FALLBACK_PROVIDER_API_KEY=sk-or-...
# AI_FALLBACK_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
# AI_FALLBACK_LIGHTWEIGHT_MODEL=meta-llama/llama-3.1-8b-instruct
# See docs/runbooks/live-ai-restore.md ("Profile A + OpenRouter fallback").

# ─── CORS (required in prod — must be an explicit origin, no wildcard) ───
# CORS_ORIGIN=http://localhost:5173

# ─── Stripe (optional for Phase 1 voice flows; needed for payment flow) ──
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Twilio (required when TELEPHONY_ENABLED=true OR EMAIL_ENABLED=true) ─
# TwilioDeliveryProvider couples SMS + SendGrid into one delivery service
# (see validateFeatureRequiredConfig in shared/config.ts:154), so even an
# email-only deployment needs the Twilio creds — without them
# /invoices/:id/send and /estimates/:id/send return 503. Set BOTH
# TELEPHONY_ENABLED=false and EMAIL_ENABLED=false to skip these checks for
# local dev that doesn't exercise the delivery path.
# TELEPHONY_ENABLED=true
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+15555550100
# Required only when telephony is enabled, until the multi-tenant
# phone-number lookup (B1) is fully on; inbound calls fall back to this
# tenant id when the lookup misses.
# TWILIO_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
# PUBLIC_API_URL=https://api.example.com   # Twilio signature verification base

# ─── SendGrid (required when EMAIL_ENABLED=true) ─────────────────────────
# EMAIL_ENABLED=true
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=hello@example.com

# ─── R2 / S3 (required when STORAGE_ENABLED=true) ────────────────────────
# STORAGE_ENABLED=true
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=serviceos-uploads
# R2_PUBLIC_URL=

# ─── Voice providers (optional; defaults to OpenAI Whisper STT / tts-1) ──
# TWILIO_MEDIA_STREAMS_ENABLED=false  # true = Media Streams path (solo launch prod)
# DEEPGRAM_API_KEY=...      # Streaming STT + keyword boost (inbound voice)
# ELEVENLABS_API_KEY=...    # Streaming TTS when TTS_PROVIDER=elevenlabs
# STT_PROVIDER=deepgram     # 'whisper' (default) or 'deepgram'
# TTS_PROVIDER=openai       # 'openai' (default) or 'elevenlabs' (after soak)

# ─── Sentry (optional; initSentry() is a no-op when DSN unset) ───────────
# SENTRY_DSN=

# ─── Prometheus /metrics auth ────────────────────────────────────────────
# Bearer token the /metrics scraper must send as `Authorization: Bearer …`.
# Optional in dev (the route allows unauthenticated scrapes when unset);
# REQUIRED in prod/staging — without it the endpoint refuses with 503 so
# tenant ids, request volumes, and pool counts can't be enumerated by an
# outside observer. Configure the scrape config (e.g. Prometheus
# `bearer_token` / `authorization`) to send the same value.
# METRICS_TOKEN=
