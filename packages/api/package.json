{
  "name": "@serviceos/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && eslint src/",
    "seed": "ts-node scripts/seed.ts",
    "seed:clean": "ts-node scripts/seed.ts --clean",
    "migrate:dryrun": "ts-node scripts/migrate-dryrun.ts"
  },
  "dependencies": {
    "@ai-service-os/shared": "*",
    "cors": "^2.8.6",
    "express": "^4.18.0",
    "openai": "^4.0.0",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@testcontainers/postgresql": "^10.7.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "supertest": "^6.3.0",
    "testcontainers": "^10.7.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
