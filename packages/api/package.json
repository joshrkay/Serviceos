{
  "name": "@serviceos/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "node --env-file-if-exists=.env -r ts-node/register src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RLS_RUNTIME_ROLE=true vitest run --config vitest.integration.config.ts",
    "test:integration:norls": "vitest run --config vitest.integration.config.ts",
    "test:integration:rls": "RLS_RUNTIME_ROLE=true vitest run --config vitest.integration.config.ts",
    "test:rls": "vitest run --config vitest.integration.config.ts test/integration/rls-tenant-isolation.test.ts",
    "test:voice-fixtures": "vitest run test/ai/orchestration/intent-classifier.launch-fixtures.test.ts test/voice/launch-slots.test.ts",
    "test:coverage": "vitest run --coverage",
    "voice-quality": "ts-node scripts/prepare-voice-quality-run.ts && vitest run -c vitest.voice-quality.config.ts && ts-node scripts/merge-voice-quality-report.ts",
    "voice-quality:watch": "vitest -c vitest.voice-quality.config.ts",
    "voice-quality:record": "VOICE_QUALITY_CASSETTE_MODE=record vitest run -c vitest.voice-quality.config.ts",
    "voice-quality:refresh": "VOICE_QUALITY_CASSETTE_MODE=refresh vitest run -c vitest.voice-quality.config.ts",
    "voice-quality:check-cassettes": "ts-node scripts/check-voice-quality-cassettes.ts",
    "voice-quality:staleness": "ts-node scripts/report-cassette-staleness.ts",
    "voice-quality:seed-cassettes": "ts-node scripts/seed-voice-quality-cassettes.ts",
    "voice-quality:layer2": "vitest run -c vitest.voice-quality-layer2.config.ts",
    "voice-quality:layer2:weekly": "VOICE_QUALITY_LAYER2_WEEKLY=true vitest run -c vitest.voice-quality-layer2.config.ts",
    "lint": "npm run lint:log-safety && tsc --noEmit -p tsconfig.lint.json",
    "check:ai-gateway-guard": "bash scripts/check-ai-gateway-guard.sh",
    "check:fk-paths": "bash scripts/check-fk-path-coverage.sh",
    "seed": "ts-node scripts/seed.ts",
    "seed:clean": "ts-node scripts/seed.ts --clean",
    "migrate:dryrun": "ts-node scripts/migrate-dryrun.ts",
    "migrate:apply": "ts-node src/db/migrate.ts",
    "validate-env": "ts-node -e \"require('./src/shared/config').validateEnvSchema(process.env); console.log('env ok');\"",
    "smoke-test": "ts-node scripts/smoke-test.ts",
    "verify:telephony": "ts-node scripts/verify-telephony-config.ts",
    "lint:log-safety": "node scripts/check-log-safety.js",
    "launch-quality-check": "tsx scripts/launch-quality-check.ts",
    "voice-load:selfcheck": "tsx scripts/voice-load-selfcheck.ts",
    "voice-load:staging": "tsx scripts/voice-load-test.ts --max 50 --ramp 60 --hold 300"
  },
  "dependencies": {
    "@ai-service-os/shared": "*",
    "@sentry/node": "^10.45.0",
    "chrono-node": "^2.9.1",
    "cors": "^2.8.6",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.1",
    "franc-min": "^6.2.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "luxon": "^3.7.2",
    "openai": "^4.0.0",
    "pg": "^8.20.0",
    "posthog-node": "^5.35.14",
    "prom-client": "^15.1.3",
    "sharp": "^0.35.1",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^6.0.0",
    "uuid": "^11.1.1",
    "ws": "^8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-check": "^4.9.0",
    "ioredis-mock": "^8.13.1",
    "supertest": "^6.3.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
