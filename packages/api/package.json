{
  "name": "@ai-service-os/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -- --grep integration",
    "migrate:up": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:create": "tsx src/db/migrate.ts create",
    "seed": "tsx src/db/seed.ts",
    "seed:clean": "tsx src/db/seed.ts --clean"
  },
  "dependencies": {
    "@clerk/express": "^1.0.0",
    "express": "^4.21.0",
    "zod": "^3.23.0",
    "pg": "^8.13.0",
    "aws-sdk": "^2.1692.0",
    "@sentry/node": "^8.0.0",
    "pino": "^9.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@faker-js/faker": "^9.0.0"
  }
}
