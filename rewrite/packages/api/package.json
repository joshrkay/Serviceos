{
  "name": "@rivet/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run --exclude 'test/integration/**'",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/static": "^7.0.4",
    "@rivet/contracts": "*",
    "@ts-rest/core": "~3.52.1",
    "@ts-rest/fastify": "~3.52.1",
    "fastify": "^4.29.0",
    "jose": "^5.9.0",
    "pg": "^8.16.0",
    "pg-boss": "^12.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.0",
    "fast-check": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
