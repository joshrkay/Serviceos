# API
PORT=3000
NODE_ENV=development
CLERK_SECRET_KEY=

# Database — Railway provides DATABASE_URL automatically when Postgres is linked.
# For local dev, use individual vars instead.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=serviceos_dev
DB_USER=serviceos
DB_PASSWORD=
DB_SSL=false
DB_MAX_CONNECTIONS=20

# CORS — set to the web frontend URL
CORS_ORIGIN=http://localhost:5173

# Web (build-time, set as Railway build arg)
VITE_API_URL=http://localhost:3000
VITE_CLERK_PUBLISHABLE_KEY=

# Webhooks
CLERK_WEBHOOK_SECRET=

# Monitoring
SENTRY_DSN=
