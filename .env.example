# API
PORT=3000
NODE_ENV=development
# Clerk — use the Development instance (pk_test_ / sk_test_).
# BOTH web and API must use the SAME instance. Also create the JWT template
# named exactly "serviceos" with tenant_id + role claims from public_metadata.
# Full checklist: docs/runbooks/clerk-setup.md
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Hermetic local only (unsigned tokens). Never set in staging/prod.
# DEV_AUTH_BYPASS=true
# Pair with web VITE_AUTH_MODE=dev when using the Clerk shim.

# Database — Railway provides DATABASE_URL automatically when Postgres is linked.
# For local dev, use individual vars instead.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=serviceos_dev
DB_USER=serviceos
DB_PASSWORD=
DB_SSL=false
DB_MAX_CONNECTIONS=20

# CORS — set to the web frontend URL
CORS_ORIGIN=http://localhost:5173

# Web (build-time, set as Railway build arg)
VITE_API_URL=http://localhost:3000
# Same publishable key as CLERK_PUBLISHABLE_KEY above (pk_test_ for local).
# Requires Clerk JWT template "serviceos" — see docs/runbooks/clerk-setup.md
VITE_CLERK_PUBLISHABLE_KEY=
# Hermetic local/CI only — aliases @clerk/clerk-react to the dev shim.
# VITE_AUTH_MODE=dev
# Customer invoice payment page — Stripe Elements publishable key (pk_live_... or pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=
# §10 onboarding v2 — sidebar shell + derived status + app-shell guard.
# Local dev / E2E: true (6-step checklist). Set false for legacy 9-step wizard.
# Production (Railway @serviceos/web): set VITE_ONBOARDING_V2_ENABLED=true
# as a service variable (rendered into /env.js at container start — no
# rebuild required). Mirror on Vercel preview if used.
VITE_ONBOARDING_V2_ENABLED=true

# §10 onboarding — Stripe subscription price for the 14-day trial.
# Required when VITE_ONBOARDING_V2_ENABLED=true and Stripe Checkout
# is in use. Format: price_<...>
STRIPE_PRICE_ID=

# §10 onboarding — base URL the API embeds in Stripe success/cancel
# URLs and the upgrade-nudge email. Defaults to http://localhost:5173.
WEB_URL=http://localhost:5173

# §10 onboarding — trial voice cap overrides (integers). Leave unset
# in production; useful for QA where you want to exercise the
# voicemail-on-cap path without burning 60 minutes of calls.
TRIAL_VOICE_MINUTES_DAILY_OVERRIDE=
TRIAL_VOICE_MINUTES_TOTAL_OVERRIDE=

# Payments (API)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Webhooks
CLERK_WEBHOOK_SECRET=

# Monitoring
SENTRY_DSN=

# Prometheus /metrics bearer token. Optional in dev (route allows
# unauthenticated scrapes when unset); REQUIRED in prod/staging — without
# it the endpoint refuses with 503 so tenant ids and traffic counters
# can't be enumerated from outside.
METRICS_TOKEN=

# ─── Solo owner launch (voice) ───────────────────────────────────────────
# Production: set TWILIO_MEDIA_STREAMS_ENABLED=true for Media Streams path.
# TWILIO_MEDIA_STREAMS_ENABLED=false
# After soak: TTS_PROVIDER=elevenlabs (default openai for local dev).
# TTS_PROVIDER=openai
# ELEVENLABS_API_KEY=          # Streaming TTS when TTS_PROVIDER=elevenlabs
# DEEPGRAM_API_KEY=            # Streaming STT + keyword boost for inbound voice
# DATABASE_URL is required in prod (no in-memory proposal store).
# Raw voice-transcript retention is encrypted at rest (AES-256-GCM). Set a
# dedicated 64-hex (32-byte) key, or it falls back to TENANT_ENCRYPTION_KEY.
# When neither is set, raw transcripts are NOT retained (no plaintext at rest).
# TRANSCRIPT_ENCRYPTION_KEY=
# TENANT_ENCRYPTION_KEY=          # Fallback for transcript encryption if TRANSCRIPT_ENCRYPTION_KEY unset

# ─── E2E / Playwright (Clerk testing tokens) ─────────────────────────────
# Required to run the journey specs that exercise real Clerk signup/login.
# Get these from the SAME Clerk dev instance you use for VITE_CLERK_PUBLISHABLE_KEY
# above, with "Testing mode" enabled in the Clerk dashboard.
# See qa/reports/2026-05-11/clerk-testing-tokens-runbook.md for the runbook.
E2E_CLERK_PUBLISHABLE_KEY=
E2E_CLERK_SECRET_KEY=
