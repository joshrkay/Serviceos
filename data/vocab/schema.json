{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://serviceos.dev/schemas/vocab.json",
  "title": "ServiceOS domain vocabulary file",
  "description": "A single trade/domain vocabulary file (hvac, plumbing, electrical, regional).",
  "type": "object",
  "required": ["domain", "terms"],
  "additionalProperties": false,
  "properties": {
    "domain": {
      "type": "string",
      "enum": ["hvac", "plumbing", "electrical", "regional"]
    },
    "terms": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/term" }
    }
  },
  "definitions": {
    "term": {
      "type": "object",
      "required": ["term", "synonyms", "category", "regions"],
      "additionalProperties": false,
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical technical term."
        },
        "synonyms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Lay phrasings / aliases a homeowner or operator might say. May be empty."
        },
        "category": {
          "type": "string",
          "enum": [
            "component",
            "system",
            "symptom",
            "service",
            "brand",
            "material",
            "consumable",
            "condition",
            "spec",
            "dialect"
          ]
        },
        "regions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Phoenix", "Texas", "Northeast", "Florida", "Pacific NW"]
          },
          "description": "US regions where the term is especially common. Empty = nationwide."
        }
      }
    }
  }
}
