{
  "name": "serviceos",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:integration": "npm run test:integration --workspace=packages/api",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "typecheck": "cd packages/api && npx tsc --project tsconfig.build.json --noEmit",
    "lint": "npm run lint --workspaces",
    "seed": "npm run seed --workspace=packages/api",
    "seed:clean": "npm run seed:clean --workspace=packages/api",
    "migrate:dryrun": "npm run migrate:dryrun --workspace=packages/api"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
