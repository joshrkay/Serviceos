# ---------------------------------------------------------------------------
# ServiceOS GTM site — environment variables
# Copy to .env.local for local dev. All Stripe values MUST be test-mode.
# ---------------------------------------------------------------------------

# Stripe (TEST MODE ONLY — a non-sk_test_ key throws at call time by design).
# Leave STRIPE_SECRET_KEY unset to run the site in DEMO MODE (simulated checkout).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_SOLO=price_xxx
STRIPE_PRICE_ID_SHOP=price_xxx
STRIPE_PRICE_ID_PRO=price_xxx

# Product hand-off after a successful trial signup. Unset -> /go-live-pending.
NEXT_PUBLIC_APP_URL=

# Canonical/OG absolute URLs + sitemap host.
NEXT_PUBLIC_SITE_URL=https://example.com

# Future: nurture engine (email). Not used by the stub yet.
RESEND_API_KEY=
